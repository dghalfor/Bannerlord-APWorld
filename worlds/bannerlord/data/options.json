      "display_name": "Dragon Banner Pieces Required",
      "description": [
        "How many Dragon Banner Pieces must be received from Archipelago",
        "before the player can merge the Dragon Banner and progress the main quest."
      ],
      "type": "Range",
      "range_start": 1,
      "range_end": 50,
      "default": 30,
      "values": {
        "easy": 10,
        "medium": 20,
        "hard": 30,
        "very_hard": 50
      },
      "group": "Main Quest"
    },
